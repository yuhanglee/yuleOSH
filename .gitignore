# yuleOSH gitignore

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Coverage
.coverage
.coverage.*
coverage.json
htmlcov/
*.py,cover

# Pytest
.pytest_cache/

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Environment
.env
.venv/
venv/

# Runtime data (persistent DB, session state)
.yuleosh/

# Dogfooding — local-only self-referential projects
self/

# OSH build artifacts (keep .gitkeep markers)
.osh/ci/
.osh/evidence/
.osh/sessions/
.osh/reviews/
.osh/store.db
