# =============================================================================
# yuleOSH Production Environment Variables
# =============================================================================
# Copy this file to .env.production and fill in your values.
#   cp deploy/.env.production.example deploy/.env.production
#
# IMPORTANT: In production, never commit .env.production to version control.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
YULEOSH_DB_URL=postgresql://yuleosh:changeme123@db:5432/yuleosh
YULEOSH_DB_USER=yuleosh
YULEOSH_DB_PASSWORD=changeme123
YULEOSH_DB_NAME=yuleosh

# ── JWT Authentication ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
YULEOSH_JWT_SECRET=replace-with-a-random-64-char-hex-string

# ── Stripe (Payment) ─────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
# Get from https://dashboard.stripe.com/webhooks (create endpoint for /api/v1/subscription/webhook)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
# Public-facing URL for Stripe redirects
YULEOSH_BASE_URL=https://yuleosh.yourdomain.com

# ── Port ──────────────────────────────────────────────────────────────────────
YULEOSH_PORT=8080

# ── Notifications (Email) ────────────────────────────────────────────────────
YULEOSH_NOTIFY_EMAIL_SMTP=smtp.example.com
YULEOSH_NOTIFY_EMAIL_FROM=noreply@yuleosh.com
YULEOSH_NOTIFY_EMAIL_TO=admin@yuleosh.com
YULEOSH_NOTIFY_EMAIL_USER=noreply@yuleosh.com
YULEOSH_NOTIFY_EMAIL_PASS=smtp-password-here
YULEOSH_NOTIFY_EMAIL_PORT=587
YULEOSH_NOTIFY_EMAIL_TLS=1

# ── Notifications (Feishu) ───────────────────────────────────────────────────
# Optional. Webhook URL for Feishu bot.
YULEOSH_NOTIFY_FEISHU_URL=

# ── Notifications (Generic Webhook) ──────────────────────────────────────────
# Optional. Generic webhook for CI/CD pipeline events.
YULEOSH_NOTIFY_WEBHOOK_URL=

# ── Stripe Price IDs ─────────────────────────────────────────────────────────
# Create products/prices in Stripe Dashboard:
#   Pro: Set stripe_price_id in yuleosh/usage/metering.py TIERS["pro"]["stripe_price_id"]
# No Stripe Price IDs are hardcoded; configure via Stripe Dashboard.

# === API Key ===
YULEOSH_API_KEY=replace-with-your-api-key

# === Demo Mode ===
YULEOSH_DEMO_ENABLED=false

# === Rate Limiting ===
YULEOSH_RATE_LIMIT=100

# === LLM Configuration ===
LLM_API_KEY=replace-with-your-llm-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
OPENAI_API_KEY=replace-with-your-openai-key
DEEPSEEK_API_KEY=replace-with-your-deepseek-key

# === Application ===
OSH_HOME=/var/lib/yuleosh

# === CI Settings ===
CI_STRICT=true
